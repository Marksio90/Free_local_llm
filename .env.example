# ─────────────────────────────────────────────
# Free Local LLM – Konfiguracja
# Skopiuj do .env i dostosuj
# ─────────────────────────────────────────────

# Model domyślny (musi być pobrany przez Ollama)
DEFAULT_MODEL=qwen3:4b

# Model do embeddingów (RAG)
EMBED_MODEL=nomic-embed-text

# GitHub Personal Access Token (opcjonalny, zwiększa limity API)
# Generuj na: https://github.com/settings/tokens
GITHUB_TOKEN=

# Klucz sesji WebUI (zmień na losowy ciąg)
WEBUI_SECRET_KEY=supersecret-change-me

# Porty serwisów (zmień jeśli zajęte)
OLLAMA_PORT=11434
WEBUI_PORT=3000
BACKEND_PORT=8080
FRONTEND_PORT=3001
CHROMA_PORT=8001

# Wydajność Ollama (1 = CPU, więcej = GPU/więcej RAM)
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
