# ─────────────────────────────────────────────
# Free Local LLM – Konfiguracja
# Skopiuj do .env i dostosuj
# ─────────────────────────────────────────────

# Model domyślny – dla 32 GB RAM możesz użyć większego modelu:
#   qwen3:4b      (~3 GB)  – najszybszy, dobry dla CPU
#   qwen3:8b      (~5 GB)  – lepszy balans jakość/szybkość
#   qwen3:14b     (~9 GB)  – wysoka jakość, wymaga >16 GB RAM
#   llama3.1:8b   (~5 GB)  – świetny do kodu
DEFAULT_MODEL=qwen3:8b

# Model do embeddingów (RAG) – nie zmieniaj bez potrzeby
EMBED_MODEL=nomic-embed-text

# GitHub Personal Access Token
# Generuj na: https://github.com/settings/tokens
# Wymagane uprawnienia: repo, read:user, gist
GITHUB_TOKEN=

# Klucz sesji (zmień na losowy ciąg)
WEBUI_SECRET_KEY=supersecret-change-me

# ─────────────────────────────────────────────
# Porty serwisów
# ─────────────────────────────────────────────
OLLAMA_PORT=11434
BACKEND_PORT=8080
FRONTEND_PORT=3001
CHROMA_PORT=8001

# ─────────────────────────────────────────────
# Wydajność Ollama – zoptymalizowane dla 32 GB RAM
# ─────────────────────────────────────────────

# Ile równoległych zapytań obsługuje Ollama jednocześnie
# 32 GB → 4 (RAG + czat + tło nie blokują się nawzajem)
OLLAMA_NUM_PARALLEL=4

# Ile modeli trzymać załadowanych w pamięci jednocześnie
# 32 GB → 3 (np. główny model + embed + zapasowy)
OLLAMA_MAX_LOADED_MODELS=3

# Jak długo trzymać model w pamięci po ostatnim użyciu
# 48h = model nie odpada z RAM między sesjami
OLLAMA_KEEP_ALIVE=48h

# Flash Attention – szybsze przetwarzanie, mniejsze zużycie pamięci
# Zalecane zawsze gdy model to obsługuje (qwen3, llama3.x, mistral)
OLLAMA_FLASH_ATTENTION=1

# Rozmiar kontekstu (tokeny jakie "pamięta" model w jednej rozmowie)
# 32 GB → spokojnie 8192, przy qwen3:4b można dać nawet 16384
OLLAMA_CONTEXT_LENGTH=8192
