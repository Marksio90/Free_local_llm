# ─────────────────────────────────────────────
# Free Local LLM – Konfiguracja
# Skopiuj do .env i dostosuj
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# MODELE
# ─────────────────────────────────────────────

# Model główny do czatu (wieloagentowy syntezator)
# Dobierz do swojego sprzętu:
#   qwen2.5-coder:7b  (~5 GB)  – ZALECANY: świetny do kodu, dobry balans
#   qwen3:4b          (~3 GB)  – szybszy, dobry dla CPU/słabszego laptopa
#   qwen3:8b          (~5 GB)  – lepszy balans jakość/szybkość (≥16 GB RAM)
#   qwen3:14b         (~9 GB)  – wysoka jakość (≥32 GB RAM)
DEFAULT_MODEL=qwen2.5-coder:7b

# Model do zadań w tle (klasyfikacja zapytań, generowanie Q&A datasetu)
# Lekki — zajmuje ~1 GB RAM, nie koliduje z czatem!
# Pobierz: docker exec llm-ollama ollama pull qwen2.5:1.5b
BACKGROUND_MODEL=qwen2.5:1.5b

# Model do embeddingów (RAG) – nie zmieniaj bez potrzeby
EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────
# TRYB LAPTOPA (8–16 GB RAM)
# ─────────────────────────────────────────────
# Ustaw na true jeśli masz ≤16 GB RAM.
# Wyłącza LoRA training, zmniejsza równoległość Ollama.
LAPTOP_MODE=false

# ─────────────────────────────────────────────
# GITHUB
# ─────────────────────────────────────────────
# Personal Access Token – model uczy się RAZ na Twoich repo
# Generuj na: https://github.com/settings/tokens
# Wymagane uprawnienia: repo, read:user, gist
GITHUB_TOKEN=

# ─────────────────────────────────────────────
# Klucz sesji
# ─────────────────────────────────────────────
WEBUI_SECRET_KEY=supersecret-change-me

# ─────────────────────────────────────────────
# Porty serwisów
# ─────────────────────────────────────────────
OLLAMA_PORT=11434
BACKEND_PORT=8080
FRONTEND_PORT=3001
CHROMA_PORT=8001

# ─────────────────────────────────────────────
# Wydajność Ollama
# ─────────────────────────────────────────────

# Dla laptopa (8–16 GB RAM):
#   OLLAMA_NUM_PARALLEL=1       → zapytania czekają w kolejce (nie zabija RAM)
#   OLLAMA_MAX_LOADED_MODELS=1  → tylko jeden model w pamięci na raz
#
# Dla mocnego komputera (≥32 GB RAM):
#   OLLAMA_NUM_PARALLEL=4
#   OLLAMA_MAX_LOADED_MODELS=3
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Jak długo trzymać model w pamięci po ostatnim użyciu
# Laptop: 5m (zwalniaj RAM jak najszybciej)
# Mocny PC: 48h (model zawsze gotowy)
OLLAMA_KEEP_ALIVE=5m

# Flash Attention – szybsze przetwarzanie, mniejsze zużycie pamięci
# Zalecane zawsze gdy GPU to obsługuje (qwen2.5, llama3.x)
OLLAMA_FLASH_ATTENTION=1

# Rozmiar kontekstu (tokeny w jednej rozmowie)
# Laptop (≤16 GB): 4096
# Mocny PC (≥32 GB): 8192–16384
OLLAMA_CONTEXT_LENGTH=4096
